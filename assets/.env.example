# Copy this to .env at the project root and fill in the secrets you actually use.
# .env is gitignored. senate.toml references these via ${VAR_NAME}.
# Only the providers referenced by your [[senator]] entries need real values —
# unused variables can be left blank.

# ---- Azure OpenAI (provider: azure) ----
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_KEY=

# ---- Google Gemini (provider: google) ----
GEMINI_API_KEY=

# ---- xAI Grok (provider: xai) ----
XAI_API_KEY=

# ---- OpenRouter (provider: openrouter, optional aggregator) ----
OPENROUTER_API_KEY=

# ---- Local LLM (provider: local; e.g. Ollama / vLLM) ----
LOCAL_LLM_BASE_URL=http://localhost:11434/v1
LOCAL_LLM_API_KEY=ollama
